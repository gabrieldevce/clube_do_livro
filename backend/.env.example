# Banco (obrigatório no Render)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# JWT para login/registro (defina no Render)
JWT_SECRET="sua-chave-secreta-aqui"

# OMDb API (para buscar filmes dinamicamente)
# Crie uma key em https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY="sua-chave-omdb-aqui"

# Porta (Render define automaticamente)
# PORT=3000
